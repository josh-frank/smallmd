{
    "name": "smallmd/smallmd",
    "description": "A tiny flat-file CMS. Drop .md files, get a website.",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "league/commonmark": "^2.4",
        "twig/twig": "^3.8",
        "symfony/yaml": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "SmallMD\\": "lib/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
